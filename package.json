{
  "name": "codebeats",
  "displayName": "CodeBeats",
  "description": "Private development tracker with Supabase backend. Track coding time, languages, and repos privately.",
  "version": "1.0.0",
  "publisher": "regisx001",
  "repository": "https://github.com/regisx001/CodeBeats.git",
  "icon": "media/logo.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "codebeats",
    "supabase",
    "time tracking",
    "coding stats",
    "private"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "bun run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codebeats-sidebar",
          "title": "CodeBeats",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codebeats-sidebar": [
        {
          "type": "webview",
          "id": "codebeats.sidebarView",
          "name": "CodeBeats"
        }
      ]
    },
    "commands": [
      {
        "command": "codebeats.setStatus",
        "title": "CodeBeats: Set Status Message"
      },
      {
        "command": "codebeats.showCodingTime",
        "title": "CodeBeats: Show Coding Time"
      },
      {
        "command": "codebeats.toggleDebug",
        "title": "CodeBeats: Debug"
      },
      {
        "command": "codebeats.openLogFile",
        "title": "CodeBeats: Open Log File…"
      },
      {
        "command": "codebeats.openConfigFile",
        "title": "CodeBeats: Open Config File…"
      }
    ],
    "configuration": {
      "title": "CodeBeats",
      "properties": {
        "codebeats.trackingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether CodeBeats heartbeat tracking is active"
        }
      }
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4"
  }
}
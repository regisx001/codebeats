{
  "name": "devglobe",
  "displayName": "DevGlobe",
  "description": "Show your live coding presence on the DevGlobe world map. Track coding time, languages, repos, and stats.",
  "version": "2.0.0",
  "publisher": "devglobe",
  "icon": "media/logo.png",
  "license": "MIT",
  "homepage": "https://devglobe.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nako0/devglobe-extension"
  },
  "bugs": {
    "url": "https://github.com/Nako0/devglobe-extension/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": [
    "devglobe",
    "globe",
    "wakatime",
    "time tracking",
    "coding stats",
    "leaderboard",
    "developer profile",
    "presence"
  ],
  "galleryBanner": {
    "color": "#115bca",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./ && cp ../devglobe-core/dist/devglobe-core.js out/",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devglobe-sidebar",
          "title": "DevGlobe",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "devglobe-sidebar": [
        {
          "type": "webview",
          "id": "devglobe.sidebarView",
          "name": "DevGlobe"
        }
      ]
    },
    "commands": [
      {
        "command": "devglobe.setStatus",
        "title": "DevGlobe: Set Status Message"
      },
      {
        "command": "devglobe.showCodingTime",
        "title": "DevGlobe: Show Coding Time"
      },
      {
        "command": "devglobe.openGlobe",
        "title": "DevGlobe: Open Globe"
      },
      {
        "command": "devglobe.toggleDebug",
        "title": "DevGlobe: Debug"
      },
      {
        "command": "devglobe.openLogFile",
        "title": "DevGlobe: Open Log File…"
      },
      {
        "command": "devglobe.openConfigFile",
        "title": "DevGlobe: Open Config File…"
      }
    ],
    "configuration": {
      "title": "DevGlobe",
      "properties": {
        "devglobe.trackingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether DevGlobe heartbeat tracking is active"
        }
      }
    }
  }
}

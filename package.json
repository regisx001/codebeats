{
  "name": "devtracker",
  "displayName": "DevTracker",
  "description": "Private development tracker with Supabase backend. Track coding time, languages, and repos privately.",
  "version": "1.0.0",
  "publisher": "private",
  "repository": "https://github.com/regisx001/DevTracker.git",
  "icon": "media/logo.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "devtracker",
    "supabase",
    "time tracking",
    "coding stats",
    "private"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devtracker-sidebar",
          "title": "DevTracker",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "devtracker-sidebar": [
        {
          "type": "webview",
          "id": "devtracker.sidebarView",
          "name": "DevTracker"
        }
      ]
    },
    "commands": [
      {
        "command": "devtracker.setStatus",
        "title": "DevTracker: Set Status Message"
      },
      {
        "command": "devtracker.showCodingTime",
        "title": "DevTracker: Show Coding Time"
      },
      {
        "command": "devtracker.toggleDebug",
        "title": "DevTracker: Debug"
      },
      {
        "command": "devtracker.openLogFile",
        "title": "DevTracker: Open Log File…"
      },
      {
        "command": "devtracker.openConfigFile",
        "title": "DevTracker: Open Config File…"
      }
    ],
    "configuration": {
      "title": "DevTracker",
      "properties": {
        "devtracker.trackingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether DevTracker heartbeat tracking is active"
        }
      }
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4"
  }
}